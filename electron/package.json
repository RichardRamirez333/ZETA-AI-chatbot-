{
  "name": "vertex",
  "version": "1.0.0",
  "description": "VERTEX - AI Chat Platform",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux"
  },
  "author": "shelby__x1 / Bakre Lamcharki",
  "license": "MIT",
  "build": {
    "appId": "com.vertex.chat",
    "productName": "VERTEX",
    "directories": {
      "output": "../dist-desktop"
    },
    "files": [
      "main.js",
      "preload.js",
      "python-server.js",
      "icon.png"
    ],
    "extraResources": [
      {
        "from": "../dist/VERTEX.exe",
        "to": "backend/VERTEX.exe"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "icon.png"
    },
    "mac": {
      "target": "dmg",
      "icon": "icon.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "icon.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}